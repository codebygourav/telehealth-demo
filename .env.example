# Project-root .env — used by docker-compose.prod.yml at build time
# Copy this file to .env and fill in the correct values.
#
# NEXT_PUBLIC_* vars are baked into Next.js Docker images at BUILD TIME.
# On Hostinger VPS set these to the live domain.
# For local docker-compose builds, set to http://localhost:8210/api/v2

NEXT_PUBLIC_API_BASE_URL=https://dr-sushil-clinic.deploymeta.com/api/v2
NEXT_PUBLIC_API_URL=https://dr-sushil-clinic.deploymeta.com/api/v2
