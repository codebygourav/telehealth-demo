APP_NAME="Telehealth Deploymeta"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
SANCTUM_STATEFUL_DOMAINS=localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=telehealth
DB_USERNAME=root
DB_PASSWORD=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

SANCTUM_TOKEN_EXPIRATION=10080
CORS_MAX_AGE=86400
CORS_SUPPORTS_CREDENTIALS=false

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
FILESYSTEM_DISK=public

PRESCRIPTION_DICTATION_ENABLED=false
PRESCRIPTION_DICTATION_INPUT_MODE=off
PRESCRIPTION_DICTATION_TEXT_MAX_CHARS=1000
PRESCRIPTION_DICTATION_SPEECH_LOCALE=en-IN
PRESCRIPTION_DICTATION_SUPPORTED_LOCALES=auto,en-IN,hi-IN,pa-IN
PRESCRIPTION_DICTATION_ALLOW_CUSTOM_LOCALE=true

USAGE_ANALYTICS_FAKE_DATA_ENABLED=false

VITE_APP_NAME="${APP_NAME}"

QUEUE_CONNECTION=sync
MAIL_ENCRYPTION=null

WHEREBY_API_KEY=
WHEREBY_SECRET=
WHEREBY_BASE_URL=https://api.whereby.dev/v1
WHEREBY_WEBHOOK_SECRET=

RAZORPAY_ENABLED=false
STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=

VAPID_SUBJECT="mailto:hello@example.com"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# External Paid Appointments Sync Database
PAID_APPOINTMENT_DB_HOST=127.0.0.1
PAID_APPOINTMENT_DB_PORT=3306
PAID_APPOINTMENT_DB_DATABASE=paid_appointments
PAID_APPOINTMENT_DB_USERNAME=root
PAID_APPOINTMENT_DB_PASSWORD=
